{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Marketplace Opening",
  "type": "object",
  "required": ["id", "company", "title", "skills_required", "status"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^O-[a-z0-9-]+-[0-9]+$"
    },
    "company": {
      "type": "string",
      "description": "Entity ID of the posting company"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "skills_required": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "budget": {
      "type": "number",
      "minimum": 0
    },
    "currency": {
      "type": "string",
      "default": "USD"
    },
    "deadline": {
      "type": "string",
      "format": "date"
    },
    "engagement_type": {
      "type": "string",
      "enum": ["task", "project", "operation"]
    },
    "minimum_reputation_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Minimum reputation score to apply"
    },
    "status": {
      "type": "string",
      "enum": ["open", "awarded", "closed"]
    },
    "awarded_to": {
      "type": ["string", "null"]
    },
    "applications": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "company": { "type": "string" },
          "price": { "type": "number" },
          "proposed_deadline": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    },
    "posted_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
